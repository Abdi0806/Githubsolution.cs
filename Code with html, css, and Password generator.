        public static async Task HandleIncomingConnections()
        {
            bool runServer = true;

            while (runServer)
            {
                HttpListenerContext ctx = await listener.GetContextAsync();

                HttpListenerRequest req = ctx.Request;
                HttpListenerResponse resp = ctx.Response;

                Console.WriteLine("Request #: {0}", ++requestCount);
                Console.WriteLine(req.Url.ToString());
                Console.WriteLine(req.HttpMethod);
                Console.WriteLine(req.UserHostName);
                Console.WriteLine(req.UserAgent);
                Console.WriteLine();


                if ((req.HttpMethod == "POST") && (req.Url.AbsolutePath == "/shutdown"))
                {
                    Console.WriteLine("Shutdown requested");
                    runServer = false;
                }

                if ((req.HttpMethod == "POST") && (req.Url.AbsolutePath == "/genpass"))
                {
                    using (var reader = new StreamReader(req.InputStream, req.ContentEncoding))
                    {
                        string body = reader.ReadToEnd();
                        int length = 12;
                        foreach (var part in body.Split('&'))
                        {
                            var kv = part.Split('=');
                            if (kv.Length == 2 && kv[0] == "length")
                                int.TryParse(kv[1], out length);
                        }
                        generertPassord = GeneratePassword(length);
                        Console.WriteLine("Generert passord: " + generertPassord);
                    }
                }


                if ((req.HttpMethod == "POST") && (req.Url.AbsolutePath == "/genphrase"))
                {
                    using (var reader = new StreamReader(req.InputStream, req.ContentEncoding))
                    {
                        string body = reader.ReadToEnd();
                        int antall = 4;
                        foreach (var part in body.Split('&'))
                        {
                            var kv = part.Split('=');
                            if (kv.Length == 2 && kv[0] == "antall")
                                int.TryParse(kv[1], out antall);
                        }
                        generertPassfrase = GeneratePassphrase(antall);
                        Console.WriteLine("Generert passfrase: " + generertPassfrase);
                    }
                }




                if (req.Url.AbsolutePath != "/favicon.ico")
                    pageViews += 1;

                string disableSubmit = !runServer ? "disabled" : "";
                // Viser plassholdertekst hvis ingenting er generert ennå
                string passordTekst = generertPassord != "" ? generertPassord : "Ingen passord generert...";
                string pasfraseTekst = generertPassfrase != "" ? generertPassfrase : "ingen pass-frase generert.";
                string passordKlasse = generertPassord == "" ? "empty" : "";
                string pasfrasKlasse = generertPassfrase == "" ? "empty" : "";

                byte[] data = Encoding.UTF8.GetBytes(
                    String.Format(pageData, pageViews, disableSubmit, passordTekst, pasfraseTekst, passordKlasse, pasfrasKlasse)
                );
                resp.ContentType = "text/html";
                resp.ContentEncoding = Encoding.UTF8;
                resp.ContentLength64 = data.LongLength;

                await resp.OutputStream.WriteAsync(data, 0, data.Length);
                resp.Close();
            }
        }



        public static void Main(string[] args)
        {
            listener = new HttpListener();
            listener.Prefixes.Add(url);
            listener.Start();
            Console.WriteLine("Listening for connections on {0}", url);

            Task listenTask = HandleIncomingConnections();
            listenTask.GetAwaiter().GetResult();

            listener.Close();
        }
