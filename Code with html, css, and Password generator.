        // genererer et nytt random passord i valgt lengde
        public static string GeneratePassword(int length) 
        {
            if (length > 200)
            {
                length = 200;
            }
            string karakterer = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!#&%=?*"; // karakterer den kan velge mellom
            var rng = new Random();                                                                      
            var sb = new StringBuilder();
            for (int i = 0; i < length; i++)
                sb.Append(karakterer[rng.Next(karakterer.Length)]);
            return sb.ToString();
        }


        public static string GeneratePassphrase(int antallOrd)
        {
            if (antallOrd > 20)
            {
                antallOrd = 20;
            }
            var rng = new Random();
            var valgte = new string[antallOrd];
            for (int i = 0; i < antallOrd; i++)
                valgte[i] = ord[rng.Next(ord.Length)];
            return string.Join("-", valgte);
        }


